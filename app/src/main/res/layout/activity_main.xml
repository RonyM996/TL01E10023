<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#0A1931"
    android:gravity="center_horizontal">

    <FrameLayout
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/imgContacto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#1A2A42"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_silueta" />

        <ImageButton
            android:id="@+id/btnCapturar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="bottom|end"
            android:backgroundTint="#1976D2"
            android:tint="#FFFFFF"
            android:src="@android:drawable/ic_menu_camera" />
    </FrameLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:text="Pais" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Spinner
            android:id="@+id/spnPais"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:backgroundTint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btnAgregarPais"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_input_add"
            android:tint="#FFFFFF"
            android:background="?attr/selectableItemBackground" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:text="Nombre" />

    <EditText
        android:id="@+id/txtNombre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textColorHint="#00B050"
        android:backgroundTint="#FFFFFF"
        android:hint="Jose de Jesus Sarmiento"
        android:inputType="textPersonName" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:text="Telefono" />

    <EditText
        android:id="@+id/txtTelefono"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textColorHint="#00B050"
        android:backgroundTint="#FFFFFF"
        android:hint="99765645"
        android:inputType="phone" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:text="Nota" />

    <EditText
        android:id="@+id/txtNota"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:gravity="top|start"
        android:inputType="textMultiLine"
        android:background="#A5D6A7"
        android:textColor="#000000"
        android:textColorHint="#424242"
        android:hint="Conocido desde la secundaria"
        android:padding="8dp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnSalvar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Salvar Contacto"
        android:backgroundTint="#00B050"
        android:textColor="#FFFFFF"/>

    <Button
        android:id="@+id/btnVerContactos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Contactos Salvados"
        android:backgroundTint="#1976D2"
        android:textColor="#FFFFFF"
        android:layout_marginTop="8dp"/>

</LinearLayout>